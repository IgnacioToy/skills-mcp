#!/usr/bin/env bash
# lcclaude-desktop — configure Claude Desktop to use Meituan LongCat as inference backend.
#
# Edits ~/Library/Application Support/Claude-3p/configLibrary/{_meta,<uuid>}.json
# and restarts Claude Desktop. macOS only.
#
# Usage:
#   lcclaude-desktop         # configure to LongCat-2.0 and restart
#   lcclaude-desktop update  # git pull latest from the repo
#   lcclaude-desktop -h      # help
#
# Reads LONGCAT_API_KEY from env or ~/.zshrc & friends (else prompts). The base URL
# defaults to https://api.longcat.chat/anthropic; override with LONGCAT_BASE_URL.
#
# Get your free API key (public beta — 500K tokens/day free):
#   https://longcat.chat/platform
#
# Note: Once a third-party gateway is active, Claude Desktop's Chat mode is
# unavailable — only Cowork (3P) and Code modes work.

set -euo pipefail

CONFIG_DIR="$HOME/Library/Application Support/Claude-3p/configLibrary"
META="$CONFIG_DIR/_meta.json"
ENTRY_NAME="lcclaude-desktop"
AUTH_SCHEME="bearer"
MAIN_MODEL="LongCat-2.0"
FAST_MODEL="LongCat-Flash-Chat"
BASE_URL="${LONGCAT_BASE_URL:-https://api.longcat.chat/anthropic}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      sed -n '2,20p' "$0" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    update)
      SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
      echo "lcclaude-desktop: pulling latest from $SELF_DIR ..."
      git -C "$SELF_DIR" pull && echo "lcclaude-desktop: updated." || {
        echo "lcclaude-desktop: git pull failed. Check network or resolve conflicts manually." >&2
        exit 1
      }
      exit 0
      ;;
    *)
      echo "lcclaude-desktop: unknown argument: $1" >&2
      echo "Run 'lcclaude-desktop -h' for usage." >&2
      exit 2
      ;;
  esac
done

preflight() {
  if [[ "$(uname)" != "Darwin" ]]; then
    echo "lcclaude-desktop: macOS only." >&2
    exit 1
  fi
  if [[ ! -d "/Applications/Claude.app" ]]; then
    echo "lcclaude-desktop: /Applications/Claude.app not found. Install from https://claude.ai/download." >&2
    exit 1
  fi
  if [[ ! -x "/usr/bin/jq" ]]; then
    echo "lcclaude-desktop: /usr/bin/jq not found (required on macOS Sonoma+)." >&2
    exit 1
  fi

  local dev_settings="$HOME/Library/Application Support/Claude/developer_settings.json"
  if [[ ! -f "$dev_settings" ]] \
     || ! /usr/bin/jq -e '.allowDevTools == true' "$dev_settings" >/dev/null 2>&1; then
    cat >&2 <<'EOF'
lcclaude-desktop: Developer Mode not enabled in Claude Desktop.

Enable it once in the GUI:
  1. Open Claude Desktop
  2. Help → Troubleshooting → Enable Developer Mode
  3. Re-run lcclaude-desktop
EOF
    exit 1
  fi
}

resolve_api_key() {
  if [[ -n "${LONGCAT_API_KEY:-}" ]]; then
    printf '%s' "$LONGCAT_API_KEY"
    return 0
  fi
  local rc found=""
  for rc in "$HOME/.zshrc" "$HOME/.bashrc" "$HOME/.bash_profile" "$HOME/.profile"; do
    [[ -r "$rc" ]] || continue
    found="$(grep -v '^[[:space:]]*#' "$rc" 2>/dev/null \
      | grep -E '^[[:space:]]*export[[:space:]]+LONGCAT_API_KEY=' \
      | tail -1 \
      | sed -E 's/^[^=]*=//; s/^"(.*)"$/\1/; s/^'\''(.*)'\''$/\1/' \
      || true)"
    if [[ -n "$found" ]]; then
      printf '%s' "$found"
      return 0
    fi
  done
  local key
  key="$(osascript <<'APPLESCRIPT' 2>/dev/null || true
try
  set theKey to text returned of (display dialog ¬
    "LongCat API Key not found in env or shell rc.\nPaste your LongCat API Key:" ¬
    default answer "" ¬
    with hidden answer ¬
    with title "lcclaude-desktop")
  return theKey
on error
  return ""
end try
APPLESCRIPT
)"
  if [[ -z "$key" ]]; then
    echo "lcclaude-desktop: no LongCat API Key provided. Aborting." >&2
    exit 1
  fi
  printf '%s' "$key"
}

confirm_or_abort() {
  echo
  echo "About to: $1"
  echo "Press Enter to continue, Ctrl-C to abort."
  read -r _
}

write_entry() {
  local uuid="$1"
  local entry_path="$CONFIG_DIR/${uuid}.json"
  local tmp="${entry_path}.tmp"
  local content
  content="$(jq -n \
    --arg baseUrl "$BASE_URL" \
    --arg apiKey  "$LC_KEY" \
    --arg auth    "$AUTH_SCHEME" \
    --arg main    "$MAIN_MODEL" \
    --arg fast    "$FAST_MODEL" \
    '{
       inferenceProvider: "gateway",
       inferenceGatewayBaseUrl: $baseUrl,
       inferenceGatewayApiKey: $apiKey,
       inferenceGatewayAuthScheme: $auth,
       unstableDisableModelVerification: true,
       inferenceModels: [
         {name: $main, supports1m: false},
         {name: $fast, supports1m: false}
       ]
     }')"
  printf '%s' "$content" > "$tmp"
  chmod 600 "$tmp"
  mv "$tmp" "$entry_path"
}

ensure_meta_entry() {
  mkdir -p "$CONFIG_DIR"
  local existing_uuid=""
  if [[ -f "$META" ]]; then
    existing_uuid="$(jq -r --arg name "$ENTRY_NAME" \
      '.entries[]? | select(.name==$name) | .id' "$META" 2>/dev/null \
      | head -1)"
  fi
  local uuid
  if [[ -n "$existing_uuid" ]]; then
    uuid="$existing_uuid"
  else
    uuid="$(uuidgen | tr 'A-Z' 'a-z')"
  fi
  local tmp="${META}.tmp"
  local content
  if [[ -f "$META" ]]; then
    content="$(jq --arg id "$uuid" --arg name "$ENTRY_NAME" '
      .appliedId = $id
      | .entries = ((.entries // []) | map(select(.name != $name)) + [{id: $id, name: $name}])
    ' "$META")"
  else
    content="$(jq -n --arg id "$uuid" --arg name "$ENTRY_NAME" \
      '{appliedId: $id, entries: [{id: $id, name: $name}]}')"
  fi
  printf '%s' "$content" > "$tmp"
  chmod 600 "$tmp"
  mv "$tmp" "$META"
  printf '%s' "$uuid"
}

restart_claude() {
  killall Claude 2>/dev/null || true
  sleep 1
  open -a Claude
}

preflight
LC_KEY="$(resolve_api_key)"
confirm_or_abort "configure Claude Desktop to use Meituan LongCat ($BASE_URL) and restart it."
UUID="$(ensure_meta_entry)"
write_entry "$UUID"
restart_claude

cat <<'EOF'

Done. Claude Desktop is restarting with Meituan LongCat as the inference backend.

Heads up: Chat mode is unavailable while a third-party gateway is active.
Re-run lcclaude-desktop any time to refresh the gateway config.
EOF
