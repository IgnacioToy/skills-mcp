# ======================================================================
# 小米 MiMo MCP Server — 环境变量示例
# 使用方式:cp .env.example .env  然后填入真实 MIMO_API_KEY
# 注意:.env 已被 .gitignore 排除,千万不要提交真实 key 到仓库
# ======================================================================

# 必填:MiMo API Key (在 https://platform.xiaomimimo.com 控制台创建)
MIMO_API_KEY=sk-请替换为你的真实key

# Endpoint
# - 普通 API Key:https://api.xiaomimimo.com/v1
# - Token Plan 套餐(tp- 前缀):用控制台「专属 Base URL」给的地址,
#   例如 https://token-plan-cn.xiaomimimo.com/v1
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# v2.5 系列是 thinking 模型(reasoning chain 默认开启,会先消耗 max_tokens 用于思考)。
# 4096 是给"思考 + 回复"留足空间的稳妥默认值;长文本任务可临时调到 8192 或 16384。
MIMO_DEFAULT_MAX_TOKENS=4096

# 默认模型(F1-F8 各自的优选项,可单独覆盖)
MIMO_DEFAULT_TEXT_MODEL=mimo-v2.5-pro
MIMO_DEFAULT_VISION_MODEL=mimo-v2.5
MIMO_DEFAULT_TTS_MODEL=mimo-v2.5-tts
MIMO_DEFAULT_VOICE_CLONE_MODEL=mimo-v2.5-tts-voiceclone
MIMO_DEFAULT_VOICE_DESIGN_MODEL=mimo-v2.5-tts-voicedesign
MIMO_DEFAULT_ASR_MODEL=mimo-v2.5-asr

# Web UI(本地管理面板)
MIMO_WEB_HOST=127.0.0.1
MIMO_WEB_PORT=7801

# 后端热重载:改 .py 或 .env 自动重启进程(开发期推荐 true,生产部署设 false)
MIMO_WEB_RELOAD=true

# 数据目录(SQLite + 生成产物 + 上传素材)
MIMO_DATA_DIR=./data

# HTTP 超时(秒);视频/克隆等长任务可能需要拉大
MIMO_HTTP_TIMEOUT=120

# 日志级别 DEBUG / INFO / WARNING / ERROR
MIMO_LOG_LEVEL=INFO
